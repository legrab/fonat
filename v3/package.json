{
  "name": "fonat",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "22.16.0",
    "npm": ">=10.9.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n server,web -c auto \"npm run dev -w @fonat/server\" \"npm run dev -w @fonat/web\"",
    "build": "npm run build -w @fonat/web && npm run build -w @fonat/server",
    "lint": "npm run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "vitest run tests/unit tests/integration",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "validate": "npm run format:check && npm run typecheck && npm test && npm run build",
    "demo:reset": "tsx scripts/demo-reset.ts",
    "package:validate": "tsx scripts/package-validate.ts",
    "openapi:generate": "tsx scripts/openapi-generate.ts"
  },
  "devDependencies": {
    "@playwright/test": "1.55.1",
    "@types/node": "^22.15.3",
    "concurrently": "9.2.1",
    "prettier": "3.9.0",
    "tsx": "4.20.5",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  }
}
