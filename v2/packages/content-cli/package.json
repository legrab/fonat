{
  "name": "@fonat/content-cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "fonat-content": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
