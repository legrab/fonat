    "test:content": "tsx src/cli.ts test",
    "pack:example": "tsx src/cli.ts pack ../../content/demo"
  },
  "dependencies": {
    "@fonat/content-contracts": "0.1.0",
    "@fonat/contracts": "0.1.0",
    "archiver": "^7.0.1",
    "commander": "^14.0.2"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.3",
    "tsx": "^4.21.0"
  }
}
