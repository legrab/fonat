{
  "name": "fonat",
  "version": "0.1.0",
  "private": true,
  "description": "Fonat teacher workspace: Thread by thread.",
  "license": "PolyForm-Noncommercial-1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "modules/*"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "concurrently -k -n server,web -c auto \"npm run dev -w @fonat/server\" \"npm run dev -w @fonat/web\"",
    "build": "node scripts/build.mjs && npm run build -w @fonat/web",
    "typecheck": "node scripts/build.mjs && npm run typecheck -w @fonat/web",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate": "npm run format:check && npm run lint && npm run typecheck && npm run test && npm run build",
    "demo:reset": "npm run demo:reset -w @fonat/server",
    "db:indexes": "npm run db:indexes -w @fonat/server",
    "package:validate": "tsx packages/content-cli/src/cli.ts validate",
    "package:test": "tsx packages/content-cli/src/cli.ts test",
    "content:pack": "tsx packages/content-cli/src/cli.ts pack content/demo",
    "start": "npm run start -w @fonat/server",
    "build:packages": "node scripts/build.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.10.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "3.2.4"
  }
}
