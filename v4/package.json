{
  "name": "fonat",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.18.0",
    "npm": "11.16.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n server,web -c auto \"npm run dev -w @fonat/server\" \"npm run dev -w @fonat/web\"",
    "build": "npm run build -w @fonat/web && npm run build -w @fonat/server",
    "lint": "npm run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "vitest run tests/unit tests/integration",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "validate": "npm run format:check && npm run typecheck && npm test && npm run build",
    "demo:reset": "tsx scripts/demo-reset.ts",
    "package:validate": "tsx scripts/package-validate.ts",
    "openapi:generate": "tsx scripts/openapi-generate.ts",
    "toolchain:check": "node scripts/check-toolchain.mjs",
    "lockfile:check": "node scripts/check-lockfile-portability.mjs",
    "config:check": "node scripts/check-config.mjs",
    "smoke:production": "node scripts/smoke-production.mjs",
    "artifact:verify": "node scripts/verify-artifact.mjs"
  },
  "devDependencies": {
    "@playwright/test": "1.55.1",
    "@types/node": "24.13.3",
    "concurrently": "9.2.1",
    "prettier": "3.9.0",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "vitest": "3.2.7",
    "yaml": "2.9.0"
  },
  "packageManager": "npm@11.16.0",
  "allowScripts": {
    "esbuild@0.25.12": true,
    "esbuild@0.27.7": true,
    "esbuild@0.28.1": true
  }
}
